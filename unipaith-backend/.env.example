# App
APP_NAME=UniPaith API
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://unipaith:unipaith@localhost:5432/unipaith

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_DOMAIN=
COGNITO_BYPASS=true
# Demo: wipe a student's data on every login (keeps the account). Assumes bypass.
DEMO_MODE=false
# "Sign in with Google" (GIS-direct): your Google OAuth Web client id. The ID
# token's audience is verified against this. Empty = Google sign-in disabled.
GOOGLE_CLIENT_ID=

# S3
S3_BUCKET_NAME=unipaith-documents
S3_PRESIGNED_URL_EXPIRY=3600
S3_LOCAL_MODE=true
S3_LOCAL_PATH=./uploads

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# AI - set to true for local dev without GPU / API keys
AI_MOCK_MODE=true
GPU_MODE=openai

# Anthropic Claude — primary user-facing LLM (Plan 2 + Spec 03)
# Sonnet 4.6 powers orchestrator/rationale/coach; Haiku 4.5 powers extractor/validator/emitter;
# Opus 4.8 reserved for "single defining moment" generations (strategy first-pass,
# packet summary, cohort review summary).
ANTHROPIC_API_KEY=
LLM_REASONING_MODEL=claude-sonnet-4-6
LLM_FEATURE_MODEL=claude-haiku-4-5
ANTHROPIC_DEFAULT_FLAGSHIP=claude-opus-4-8
ANTHROPIC_DEFAULT_WORKHORSE=claude-sonnet-4-6
ANTHROPIC_DEFAULT_BATCH=claude-haiku-4-5-20251001

# Spec 03 §5/§6 — provider abstraction. Default provider for every agent
# unless a per-agent override is set in AI_PROVIDER_PER_AGENT_JSON.
AI_PROVIDER_DEFAULT=anthropic
# Optional per-agent overrides, JSON-encoded.
# AI_PROVIDER_PER_AGENT_JSON={"match_rationale":"openai"}
AI_PROVIDER_PER_AGENT_JSON=

# Spec 03 §9 — failover order, left-to-right. After all providers fail,
# the rule-based fallback runs. One audit ledger row per attempt.
AI_PROVIDER_FAILOVER_CSV=anthropic,openai
AI_PROVIDER_FAILOVER_TIMEOUT_MS=30000

# Voyage embeddings — 1024-d voyage-3-large for the new feature-vector pipeline
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIMENSION=1024

# OpenAI — legacy, kept for the offline crawler/extractor only
OPENAI_API_KEY=

# Knowledge engine — when frontier is empty, seed these (comma-separated) or use app defaults
ENGINE_BOOTSTRAP_ENABLED=true
# ENGINE_BOOTSTRAP_URLS=https://example.edu/page,https://www.ed.gov/

# ML Loop
FAIRNESS_DIAL=0.5
