# App
APP_NAME=UniPaith API
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://unipaith:unipaith@localhost:5432/unipaith

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_DOMAIN=
COGNITO_BYPASS=true

# S3
S3_BUCKET_NAME=unipaith-documents
S3_PRESIGNED_URL_EXPIRY=3600
S3_LOCAL_MODE=true
S3_LOCAL_PATH=./uploads

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# AI - set to true for local dev without GPU / API keys
AI_MOCK_MODE=true
GPU_MODE=openai

# Anthropic Claude — primary user-facing LLM (Plan 2)
# Sonnet 4.6 powers orchestrator/rationale/coach; Haiku 4.5 powers extractor/validator/emitter
ANTHROPIC_API_KEY=
LLM_REASONING_MODEL=claude-sonnet-4-6
LLM_FEATURE_MODEL=claude-haiku-4-5

# Voyage embeddings — 1024-d voyage-3-large for the new feature-vector pipeline
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIMENSION=1024

# OpenAI — legacy, kept for the offline crawler/extractor only
OPENAI_API_KEY=

# Knowledge engine — when frontier is empty, seed these (comma-separated) or use app defaults
ENGINE_BOOTSTRAP_ENABLED=true
# ENGINE_BOOTSTRAP_URLS=https://example.edu/page,https://www.ed.gov/

# ML Loop
FAIRNESS_DIAL=0.5
