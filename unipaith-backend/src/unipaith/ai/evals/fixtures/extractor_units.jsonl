// Phase A1 — initial extractor accuracy fixtures.
// Format: one JSON object per line. Use `// ` for comments (parser strips).
// Schema version: 1 (see ai/tools/extractor_schema.py)
//
// Each unit:
//   id              — stable identifier
//   student_turn    — the verbatim user message to extract from
//   expected        — partial expected output; absent keys are not graded
//   notes           — context for the labeler (not graded)
{"id": "u001", "student_turn": "I'm a senior at SUNY Binghamton, 3.9 GPA, and I'm looking at ML PhD programs.", "expected": {"basic": {"education_level": "bachelors", "gpa": 3.9, "age": null}, "personality": [{"facet": "career_direction", "value": "machine learning research"}], "confidence": {"basic": 0.9, "personality": 0.8}}, "notes": "Clean basic-layer extraction; education_level inferred from 'senior at [4-year]'."}
{"id": "u002", "student_turn": "I want to be a family-medicine doctor. By when? I want to be in residency by 2031.", "expected": {"goals": [{"category": "academic", "specific": "become a family-medicine doctor", "time_bound": "in residency by 2031", "completeness": 0.6}], "confidence": {"goals": 0.7}}, "notes": "Specific + time_bound present, others null. completeness must be < 1."}
{"id": "u003", "student_turn": "I think the world is better when more people can build software. That's why I tutor kids on weekends.", "expected": {"identity": [{"facet": "value", "claim": "broadening access to building software", "evidence": "the world is better when more people can build software"}], "confidence": {"identity": 0.85}}, "notes": "Real value claim with concrete behavioral evidence."}
{"id": "u004", "student_turn": "I like coding I guess.", "expected": {"personality": [{"facet": "interest", "value": "coding"}], "confidence": {"personality": 0.4}}, "notes": "Casual statement — should NOT be promoted to identity claim. Confidence low."}
{"id": "u005", "student_turn": "California's too far from my parents — I need to stay in the Northeast.", "expected": {"basic": {"location_avoid": ["US-CA"]}, "needs": [{"maslow_level": "social", "signal": "near_family", "severity": 4, "evidence": "California's too far from my parents"}], "confidence": {"basic": 0.85, "needs": 0.85}}, "notes": "Both basic location_avoid and a Maslow social signal. Don't double-extract location_prefs."}
{"id": "u006", "student_turn": "I'm 22, finished my bachelor's last year and I've been working at a startup since then.", "expected": {"basic": {"age": 22, "education_level": "working"}, "confidence": {"basic": 0.9}}, "notes": "Working past graduation → education_level='working' (gap_year is for explicit gap before grad)."}
{"id": "u007", "student_turn": "Both my parents went to college, but my mom was first-gen herself.", "expected": {"basic": {"first_gen": false}, "confidence": {"basic": 0.9}}, "notes": "Question is about THIS student's first-gen status; their mother's history is context, not the answer."}
{"id": "u008", "student_turn": "I scored a 332 on the GRE. My GPA is 3.7.", "expected": {"basic": {"gpa": 3.7, "test_scores": [{"type": "GRE", "score": 332}]}, "confidence": {"basic": 0.95}}, "notes": "Both signals — extractor must capture both, not pick one."}
{"id": "u009", "student_turn": "I changed my mind about med school halfway through sophomore year. I had been pushing through it because everyone expected me to.", "expected": {"identity": [{"facet": "self_awareness", "claim": "noticed pursuing medicine because of others' expectations rather than own desire", "evidence": "I had been pushing through it because everyone expected me to"}], "confidence": {"identity": 0.85}}, "notes": "Self-awareness moment with concrete trigger. Quality identity signal."}
{"id": "u010", "student_turn": "I'd love a small cohort. Big lecture halls drain me and I do my best work in deep one-on-one mentorship.", "expected": {"personality": [{"facet": "peer_style", "value": "small cohort", "evidence": "I'd love a small cohort"}, {"facet": "connection_style", "value": "mentorship-driven", "evidence": "deep one-on-one mentorship"}], "confidence": {"personality": 0.85}}, "notes": "Two distinct personality signals from one turn — both extracted with their own evidence quotes."}
{"id": "u011", "student_turn": "Funding is non-negotiable. I've been TAing to cover textbooks and we just can't afford anything more.", "expected": {"needs": [{"maslow_level": "safety", "signal": "low_income_aid", "severity": 5, "evidence": "Funding is non-negotiable"}], "confidence": {"needs": 0.9}}, "notes": "Explicit 'non-negotiable' → severity 5 (must_have after mapping)."}
{"id": "u012", "student_turn": "I want to publish 3 first-author papers in top venues by the end of my second PhD year.", "expected": {"goals": [{"category": "academic", "specific": "publish 3 first-author papers in top venues", "measurable": "3 first-author papers", "time_bound": "by end of second PhD year", "completeness": 0.8}], "confidence": {"goals": 0.85}}, "notes": "Specific + measurable + time_bound; achievable + relevant unstated → completeness ~0.6-0.8."}
{"id": "u013", "student_turn": "I'd love to recommend Stanford or Berkeley — what do you think?", "expected": {"confidence": {"basic": 0.0, "personality": 0.0}}, "notes": "Trick: the student is asking ABOUT a school. No factual signal to extract; orchestrator must redirect (separate eval). Extractor returns empty."}
{"id": "u014", "student_turn": "I want my research to actually help people, not just publish papers.", "expected": {"identity": [{"facet": "value", "claim": "research must have real-world impact", "evidence": "I want my research to actually help people, not just publish papers"}], "confidence": {"identity": 0.85}}, "notes": "Strong value claim. Note the 'not X but Y' structure — extract the affirmative, not the negation."}
{"id": "u015", "student_turn": "Honestly Stanford feels really out of reach. I'm the first in my family to do this.", "expected": {"basic": {"first_gen": true}, "personality": [{"facet": "conflict_style", "value": "self-doubt about reach schools", "evidence": "Stanford feels really out of reach"}], "confidence": {"basic": 0.9, "personality": 0.7}}, "notes": "First-gen confirmed AND a personality signal about confidence. Both extracted; don't conflate."}
{"id": "u016", "student_turn": "I'm pretending I don't care about prestige but honestly I do, a little. I want my parents to feel like the sacrifice was worth it.", "expected": {"identity": [{"facet": "self_awareness", "claim": "acknowledges suppressed desire for prestige tied to family sacrifice", "evidence": "I'm pretending I don't care about prestige but honestly I do"}], "confidence": {"identity": 0.9}}, "notes": "Premium identity material — vulnerability + concrete reason. The 'pretending → admitting' arc is the self-awareness."}
{"id": "u017", "student_turn": "I'm gay and I want to make sure I'm somewhere safe. The current political climate in some states scares me.", "expected": {"needs": [{"maslow_level": "safety", "signal": "lgbtq_safety", "severity": 5, "evidence": "I want to make sure I'm somewhere safe"}], "confidence": {"needs": 0.9}}, "notes": "High-severity safety need. Don't paraphrase the identity disclosure into a 'value claim' — it's a need signal, not an identity claim."}
{"id": "u018", "student_turn": "I think people overrate brand. The work matters more than where you do it.", "expected": {"identity": [{"facet": "view", "claim": "work quality matters more than institutional brand", "evidence": "The work matters more than where you do it"}], "confidence": {"identity": 0.85}}, "notes": "Worldview / view facet, not value. The framework distinguishes — view = how-the-world-works belief; value = what-matters-to-me commitment."}
{"id": "u019", "student_turn": "Toronto and Boston are in. London too if I can swing the cost.", "expected": {"basic": {"location_prefs": ["CA-ON", "US-MA", "GB"]}, "confidence": {"basic": 0.85}}, "notes": "City-level → ISO-3166 region codes. London is at country level since GB has no clean sub-region for the city in this vocabulary."}
{"id": "u020", "student_turn": "Yeah uh I dunno about that.", "expected": {"confidence": {"basic": 0.2, "personality": 0.2}}, "notes": "Filler / refusal. Extract NOTHING with confidence; the orchestrator's job is to probe differently next turn."}
