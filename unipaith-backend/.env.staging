# Staging — ~$724/month (8B always-on, no 70B)
# Real LLM for feature extraction + embeddings
# Template-based reasoning (no 70B to save costs)

ENVIRONMENT=staging
DEBUG=false
DATABASE_URL=postgresql+asyncpg://unipaith:CHANGEME@your-rds-host:5432/unipaith

# AI Engine — AWS GPU
GPU_MODE=aws
AI_MOCK_MODE=false
GPU_8B_INSTANCE_ID=i-CHANGEME          # from: terraform output gpu_8b_instance_id
GPU_8B_ENDPOINT=http://CHANGEME:8001   # from: terraform output gpu_8b_private_ip
GPU_70B_INSTANCE_ID=                    # leave empty to skip 70B
GPU_70B_ENDPOINT=

# Cost controls
GPU_MONTHLY_BUDGET_CAP=800
GPU_70B_MAX_DAILY_HOURS=0              # no 70B usage

# Scheduler
SCHEDULER_ENABLED=true

# Auth
COGNITO_BYPASS=false
COGNITO_USER_POOL_ID=CHANGEME
COGNITO_APP_CLIENT_ID=CHANGEME
