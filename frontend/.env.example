# Backend API base (defaults to http://localhost:8000/api/v1 in dev).
VITE_API_URL=http://localhost:8000/api/v1

# "Sign in with Google": your Google OAuth Web client id. When set, the
# Google button renders on the login page. Must match the backend
# GOOGLE_CLIENT_ID. Leave empty to hide the button (email login still works).
VITE_GOOGLE_CLIENT_ID=
